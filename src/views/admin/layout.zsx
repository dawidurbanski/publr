const icon_logout =
    \\<svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16 17L21 12M21 12L16 7M21 12H9M9 3H7.8C6.11984 3 5.27976 3 4.63803 3.32698C4.07354 3.6146 3.6146 4.07354 3.32698 4.63803C3 5.27976 3 6.11984 3 7.8V16.2C3 17.8802 3 18.7202 3.32698 19.362C3.6146 19.9265 4.07354 20.3854 4.63803 20.673C5.27976 21 6.11984 21 7.8 21H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;
const icon_search =
    \\<svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 21L17.5001 17.5M20 11.5C20 16.1944 16.1944 20 11.5 20C6.80558 20 3 16.1944 3 11.5C3 6.80558 6.80558 3 11.5 3C16.1944 3 20 6.80558 20 11.5Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;
const icon_chevron_right =
    \\<svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;

pub fn Layout(title: []const u8, content: []const u8, actions: []const u8, nav_dashboard: bool, nav_posts: bool, nav_users: bool, nav_users_all: bool, nav_users_new: bool, nav_users_profile: bool, nav_settings: bool, nav_components: bool, nav_design_system: bool, csrf_token: []const u8) {
    <!DOCTYPE html>
    <html>
        <head>
            <meta charset="utf-8" />
            <meta
                name="viewport"
                content="width=device-width, initial-scale=1"
            />
            <title>{title} - Publr Admin</title>
            <link rel="stylesheet" href="/static/admin.css" />
        </head>
        <body class="admin">
            <aside class="sidebar">
                <div class="sidebar-header">
                    <a href="/admin" class="logo">Publr</a>
                    <button class="sidebar-search-btn" type="button" aria-label="Search">
                        {!icon_search}
                    </button>
                </div>
                <nav class="sidebar-nav" data-publr-component="nav-slider">
                    <div class={if (nav_users) ("nav-slider submenu-open") else ("nav-slider")}>
                        <div class="nav-panel nav-panel-main" data-publr-part="main">
                            <a
                                href="/admin"
                                class={if (nav_dashboard) ("nav-item active") else ("nav-item")}
                            >
                                <span class="nav-icon">{!icon_home}</span>
                                Dashboard
                            </a>
                            <a
                                href="/admin/posts"
                                class={if (nav_posts) ("nav-item active") else ("nav-item")}
                            >
                                <span class="nav-icon">{!icon_edit}</span>
                                Posts
                            </a>
                            <button
                                type="button"
                                class={if (nav_users) ("nav-item has-submenu active") else ("nav-item has-submenu")}
                                data-publr-part="trigger"
                                data-publr-submenu="users"
                            >
                                <span class="nav-icon">{!icon_users}</span>
                                Users
                                <span class="nav-chevron">{!icon_chevron_right}</span>
                            </button>
                            <a
                                href="/admin/settings"
                                class={if (nav_settings) ("nav-item active") else ("nav-item")}
                            >
                                <span class="nav-icon">{!icon_settings}</span>
                                Settings
                            </a>
                            <a
                                href="/admin/components"
                                class={if (nav_components) ("nav-item active") else ("nav-item")}
                            >
                                <span class="nav-icon">{!icon_components}</span>
                                Components
                            </a>
                            <a
                                href="/admin/design-system"
                                class={if (nav_design_system) ("nav-item active") else ("nav-item")}
                            >
                                <span class="nav-icon">{!icon_file}</span>
                                Design System
                            </a>
                        </div>
                        <div class="nav-panel nav-panel-sub" data-publr-part="submenu" data-publr-submenu="users">
                            <button type="button" class="nav-back" data-publr-part="back">
                                <span class="nav-back-icon">{!icon_chevron_right}</span>
                                <span class="nav-back-title">Users</span>
                            </button>
                            <div class="nav-submenu-items">
                                <a
                                    href="/admin/users"
                                    class={if (nav_users_all) ("nav-subitem active") else ("nav-subitem")}
                                >
                                    All Users
                                </a>
                                <a
                                    href="/admin/users/new"
                                    class={if (nav_users_new) ("nav-subitem active") else ("nav-subitem")}
                                >
                                    Add New
                                </a>
                                <a
                                    href="/admin/users/profile"
                                    class={if (nav_users_profile) ("nav-subitem active") else ("nav-subitem")}
                                >
                                    Profile
                                </a>
                            </div>
                        </div>
                    </div>
                </nav>
                <div class="sidebar-footer">
                    <form method="POST" action="/admin/logout">
                        <input type="hidden" name="_csrf" value={csrf_token} />
                        <button type="submit" class="logout-button">
                            <span class="nav-icon">{!icon_logout}</span>
                            Logout
                        </button>
                    </form>
                </div>
            </aside>
            <main class="main-content">
                <div class="content-wrapper">
                    <header class="content-header">
                        <div class="content-header-left">
                            <h1 class="page-title">{title}</h1>
                        </div>
                        <div class="content-header-right">
                            {!actions}
                        </div>
                    </header>
                    <div class="content-body">
                        {!content}
                    </div>
                </div>
            </main>
            <script type="module" src="/static/interact/index.js"></script>
            <script src="/static/admin.js"></script>
        </body>
    </html>
}
