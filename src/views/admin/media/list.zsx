const icon_lock =
    \\<svg class="icon icon-sm" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 11V8C17 5.23858 14.7614 3 12 3C9.23858 3 7 5.23858 7 8V11M12 14.5V16.5M9.8 21H14.2C15.8802 21 16.7202 21 17.362 20.673C17.9265 20.3854 18.3854 19.9265 18.673 19.362C19 18.7202 19 17.8802 19 16.2V15.8C19 14.1198 19 13.2798 18.673 12.638C18.3854 12.0735 17.9265 11.6146 17.362 11.327C16.7202 11 15.8802 11 14.2 11H9.8C8.11984 11 7.27976 11 6.63803 11.327C6.07354 11.6146 5.6146 12.0735 5.32698 12.638C5 13.2798 5 14.1198 5 15.8V16.2C5 17.8802 5 18.7202 5.32698 19.362C5.6146 19.9265 6.07354 20.3854 6.63803 20.673C7.27976 21 8.11984 21 9.8 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;
const icon_folder =
    \\<svg class="icon icon-sm" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 7L11.8845 4.76892C11.5634 4.1268 11.4029 3.80573 11.1634 3.57116C10.9516 3.36373 10.6963 3.20597 10.4161 3.10931C10.0992 3 9.74021 3 9.02229 3H5.2C4.0799 3 3.51984 3 3.09202 3.21799C2.71569 3.40973 2.40973 3.71569 2.21799 4.09202C2 4.51984 2 5.0799 2 6.2V7M2 7H17.2C18.8802 7 19.7202 7 20.362 7.32698C20.9265 7.6146 21.3854 8.07354 21.673 8.63803C22 9.27976 22 10.1198 22 11.8V16.2C22 17.8802 22 18.7202 21.673 19.362C21.3854 19.9265 20.9265 20.3854 20.362 20.673C19.7202 21 18.8802 21 17.2 21H6.8C5.11984 21 4.27976 21 3.63803 20.673C3.07354 20.3854 2.6146 19.9265 2.32698 19.362C2 18.7202 2 17.8802 2 16.2V7Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;
const icon_sync =
    \\<svg class="icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 10C21 10 18.995 7.26822 17.3662 5.63824C15.7373 4.00827 13.4864 3 11 3C6.02944 3 2 7.02944 2 12C2 16.9706 6.02944 21 11 21C15.1031 21 18.5649 18.2543 19.6482 14.5M21 10V4M21 10H15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;
const icon_tag =
    \\<svg class="icon icon-sm" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2 12L11.6422 2.35783C11.8405 2.15953 11.9396 2.06038 12.0558 1.98697C12.1588 1.92191 12.2711 1.87276 12.389 1.84115C12.5221 1.80544 12.6631 1.80078 12.945 1.79148L18.2889 1.61571C19.0558 1.59043 19.4392 1.57779 19.7301 1.72C19.9853 1.84519 20.1927 2.04907 20.3223 2.30189C20.4694 2.58969 20.4632 2.97309 20.4507 3.73989L20.3508 9.0844C20.3457 9.36634 20.3432 9.50731 20.3113 9.64061C20.283 9.75858 20.2371 9.87138 20.1751 9.97537C20.105 10.0929 20.0088 10.1946 19.8165 10.3982L10.5 20M2 12L10.5 20M2 12L5 9M10.5 20L13 17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
;

const MediaItem = struct {
    id: []const u8,
    filename: []const u8,
    mime_type: []const u8,
    size_display: []const u8,
    visibility: []const u8,
    edit_url: []const u8,
    delete_url: []const u8,
    thumb_url: []const u8,
    is_image: bool,
    is_private: bool,
};

const FolderItem = struct {
    id: []const u8,
    name: []const u8,
    parent_id: []const u8,
    count: u32,
    is_active: bool,
    url: []const u8,
};

const TagItem = struct {
    id: []const u8,
    name: []const u8,
    count: u32,
    is_active: bool,
    url: []const u8,
};

pub fn List(props: struct {
    has_media: bool,
    media: []const MediaItem,
    csrf_token: []const u8,
    view_mode: []const u8,
    total_count: u32,
    folders: []const FolderItem,
    tags: []const TagItem,
    active_folder: []const u8,
    active_tag: []const u8,
    show_unreviewed: bool,
    unreviewed_count: u32,
    view_grid_url: []const u8,
    view_list_url: []const u8,
}) {
    <div class="media-upload-zone" id="media-upload-zone" data-publr-component="upload-zone">
        <form method="POST" action="/admin/media" enctype="multipart/form-data" id="media-upload-form">
            <input type="hidden" name="_csrf" value={props.csrf_token} />
            <div class="upload-zone-content">
                <div class="upload-zone-icon">{!icon_upload}</div>
                <p class="upload-zone-text">
                    <label for="media-file-input" class="upload-zone-link">Click to upload</label>
                    {" or drag and drop"}
                </p>
                <p class="upload-zone-hint">Max file size: 1MB</p>
                <input type="file" id="media-file-input" name="file" class="upload-zone-input" multiple="" />
            </div>
            <div class="upload-zone-progress" id="upload-progress" style="display:none">
                <div class="upload-progress-bar" id="upload-progress-bar"></div>
                <span class="upload-progress-text" id="upload-progress-text">Uploading...</span>
            </div>
        </form>
    </div>

    <div class="media-toolbar">
        <div class="media-toolbar-left">
            <span class="media-count">{props.total_count} files</span>
            <form method="POST" action="/admin/media/sync" class="media-sync-form">
                <input type="hidden" name="_csrf" value={props.csrf_token} />
                <button type="submit" class="btn btn-sm media-sync-btn" title="Sync filesystem">
                    {!icon_sync}
                    {" Sync"}
                </button>
            </form>
        </div>
        <div class="media-toolbar-right">
            <div class="media-filters">
                <a href="/admin/media" class={if (props.active_folder.len == 0 and props.active_tag.len == 0 and !props.show_unreviewed) ("media-filter-btn active") else ("media-filter-btn")}>All</a>
                {if (props.unreviewed_count > 0) (
                    <a href="?unreviewed=1" class={if (props.show_unreviewed) ("media-filter-btn active") else ("media-filter-btn")}>
                        {"Unreviewed "}
                        <span class="media-filter-count">{props.unreviewed_count}</span>
                    </a>
                ) else (<span></span>)}
            </div>
            <div class="media-view-toggle">
                <a href={props.view_grid_url} class={if (std.mem.eql(u8, props.view_mode, "grid")) ("media-view-btn active") else ("media-view-btn")} aria-label="Grid view">
                    {!icon_grid}
                </a>
                <a href={props.view_list_url} class={if (std.mem.eql(u8, props.view_mode, "list")) ("media-view-btn active") else ("media-view-btn")} aria-label="List view">
                    {!icon_list}
                </a>
            </div>
        </div>
    </div>

    <div class="media-layout">
        <aside class="media-sidebar">
            <div class="media-sidebar-section">
                <div class="media-sidebar-header">
                    <h3 class="media-sidebar-title">Folders</h3>
                </div>
                <ul class="media-folder-list">
                    {for (props.folders) |folder| (
                        <li class={if (folder.is_active) ("media-folder-item active") else ("media-folder-item")}>
                            <a href={folder.url} class="media-folder-link">
                                {!icon_folder}
                                <span class="media-folder-name">{folder.name}</span>
                                <span class="media-folder-count">{folder.count}</span>
                            </a>
                        </li>
                    )}
                </ul>
                <form method="POST" action="/admin/media/folders" class="media-sidebar-form">
                    <input type="hidden" name="_csrf" value={props.csrf_token} />
                    <input type="text" name="folder_name" placeholder="New folder..." class="form-control form-control-sm" />
                </form>
            </div>

            <div class="media-sidebar-section">
                <div class="media-sidebar-header">
                    <h3 class="media-sidebar-title">Tags</h3>
                </div>
                <div class="media-tag-list">
                    {for (props.tags) |tag| (
                        <a href={tag.url} class={if (tag.is_active) ("media-tag-chip active") else ("media-tag-chip")}>
                            {tag.name}
                            <span class="media-tag-count">{tag.count}</span>
                        </a>
                    )}
                </div>
                <form method="POST" action="/admin/media/tags" class="media-sidebar-form">
                    <input type="hidden" name="_csrf" value={props.csrf_token} />
                    <input type="text" name="tag_name" placeholder="New tag..." class="form-control form-control-sm" />
                </form>
            </div>
        </aside>

        <div class="media-content">
            {if (props.has_media) (
                {if (std.mem.eql(u8, props.view_mode, "grid")) (
                    <div class="media-grid">
                        {for (props.media) |item| (
                            <a href={item.edit_url} class="media-card">
                                <div class="media-card-preview">
                                    {if (item.is_image) (
                                        <img src={item.thumb_url} alt={item.filename} loading="lazy" />
                                    ) else (
                                        <div class="media-card-icon">{!icon_file}</div>
                                    )}
                                    {if (item.is_private) (
                                        <span class="media-card-badge">{!icon_lock}</span>
                                    ) else (<span></span>)}
                                </div>
                                <div class="media-card-info">
                                    <span class="media-card-name">{item.filename}</span>
                                    <span class="media-card-meta">{item.size_display}</span>
                                </div>
                            </a>
                        )}
                    </div>
                ) else (
                    <table class="table">
                        <thead>
                            <tr>
                                <th class="table-col-check">
                                    <input type="checkbox" class="table-checkbox" aria-label="Select all" />
                                </th>
                                <th class="table-col-thumb"></th>
                                <th>Filename</th>
                                <th>Type</th>
                                <th>Size</th>
                                <th>Visibility</th>
                                <th class="actions-col"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {for (props.media) |item| (
                                <tr>
                                    <td class="table-col-check">
                                        <input type="checkbox" class="table-checkbox" value={item.id} aria-label="Select media" />
                                    </td>
                                    <td class="table-col-thumb">
                                        {if (item.is_image) (
                                            <div class="table-thumb">
                                                <img src={item.thumb_url} alt={item.filename} />
                                            </div>
                                        ) else (
                                            <div class="table-thumb">{!icon_file}</div>
                                        )}
                                    </td>
                                    <td>
                                        <a href={item.edit_url}>{item.filename}</a>
                                    </td>
                                    <td>{item.mime_type}</td>
                                    <td>{item.size_display}</td>
                                    <td>
                                        <span class={if (item.is_private) ("badge badge-draft") else ("badge badge-published")}>{item.visibility}</span>
                                    </td>
                                    <td class="actions-col">
                                        <div data-publr-component="dropdown">
                                            <button class="table-actions-btn" data-publr-part="trigger" aria-label="Actions">
                                                {!icon_more}
                                            </button>
                                            <div class="dropdown-menu" data-publr-part="content">
                                                <a href={item.edit_url} class="dropdown-item">Edit</a>
                                                <hr class="dropdown-divider" />
                                                <form method="POST" action={item.delete_url}>
                                                    <input type="hidden" name="_csrf" value={props.csrf_token} />
                                                    <button type="submit" class="dropdown-item dropdown-item-danger" onclick="return confirm('Delete this file permanently?')">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            )}
                        </tbody>
                    </table>
                )}
            ) else (
                <div class="empty-state">
                    <div class="empty-state-icon">{!icon_image}</div>
                    <p>No media files yet.</p>
                    <p class="empty-state-hint">Upload files by clicking the zone above or dragging files onto it.</p>
                </div>
            )}
        </div>
    </div>
}

