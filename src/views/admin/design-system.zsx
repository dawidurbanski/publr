                    <p class="ds-specimen-chars">ABCDEFGHIJKLMNOPQRSTUVWXYZ</p>
                    <p class="ds-specimen-chars">abcdefghijklmnopqrstuvwxyz</p>
                    <p class="ds-specimen-chars">0123456789</p>
