            </div>

            <div class="ds-subsection">
                <h3 class="ds-subsection-title">Display Scale</h3>
                <div class="ds-type-scale">
                    <div class="ds-type-row">
                        <span class="ds-type-sample" style="font-size: 72px; line-height: 90px; letter-spacing: -2px;">Display 2xl</span>
                        <div class="ds-type-meta">
