                </div>
                <div class="ds-spacing-item">
                    <div class="ds-spacing-bar" style="width: 64px;"></div>
                    <span class="ds-spacing-name">spacing-7xl</span>
                    <span class="ds-spacing-value">64px</span>
                </div>
                <div class="ds-spacing-item">
                    <div class="ds-spacing-bar" style="width: 80px;"></div>
                    <span class="ds-spacing-name">spacing-8xl</span>
                    <span class="ds-spacing-value">80px</span>
                </div>
                <div class="ds-spacing-item">
                    <div class="ds-spacing-bar" style="width: 128px;"></div>
                    <span class="ds-spacing-name">spacing-10xl</span>
                    <span class="ds-spacing-value">128px</span>
                </div>
            </div>
        </section>

        <section class="ds-section">
            <h2 class="ds-section-title">Border Radius</h2>

            <div class="ds-radius-list">
                <div class="ds-radius-item">
                    <div class="ds-radius-box" style="border-radius: 12px;"></div>
                    <div class="ds-radius-info">
                        <span class="ds-radius-name">radius-xl</span>
                        <span class="ds-radius-value">12px</span>
                    </div>
                </div>
                <div class="ds-radius-item">
                    <div class="ds-radius-box" style="border-radius: 20px;"></div>
                    <div class="ds-radius-info">
                        <span class="ds-radius-name">radius-3xl</span>
                        <span class="ds-radius-value">20px</span>
                    </div>
                </div>
                <div class="ds-radius-item">
                    <div class="ds-radius-box" style="border-radius: 9999px;"></div>
                    <div class="ds-radius-info">
                        <span class="ds-radius-name">radius-full</span>
                        <span class="ds-radius-value">9999px</span>
                    </div>
                </div>
            </div>
        </section>
    </div>
}
