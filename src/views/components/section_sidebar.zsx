// Section sidebar — vertical nav items in the content section sidebar

pub fn SectionSidebar(props: struct { items: anytype }) {
    {for (props.items) |item| (
        <a
            href={item.path}
            class={if (item.is_active) "section-nav-item active" else "section-nav-item"}
        >
            <span class="nav-icon">{@raw item.icon}</span>
            {item.label}
        </a>
    )}
}
