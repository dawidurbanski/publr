---
const slug = ctx.param("slug") orelse "unknown";
const page = try ctx.entry(.page, slug);
---
<Base>
  <article>
    <a href="/pages" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">← Back to all pages</a>
    <h1 class="text-3xl font-bold mb-6">{page.title}</h1>
    <div class="prose prose-gray">
      {@raw page.data.body}
    </div>
  </article>
</Base>
