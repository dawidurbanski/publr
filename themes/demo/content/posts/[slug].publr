---
const slug = ctx.param("slug") orelse "unknown";
const post = try ctx.entry(.post, slug);
---
<Base>
  <article>
    <a href="/posts" class="text-sm text-gray-500 hover:text-gray-700 mb-4 inline-block">← Back to all posts</a>
    <h1 class="text-3xl font-bold mb-6">{post.title}</h1>
    <div class="prose prose-gray">
      {@raw post.data.body}
    </div>
  </article>
</Base>
